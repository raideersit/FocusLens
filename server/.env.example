# ─────────────────────────────────────────────────────────────────────────────
# Configuración del backend FocusLens
# Copia este archivo como `.env` (en server/) y rellena con tus credenciales.
# El archivo `.env` NO debe subirse al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Neon (PostgreSQL) ─────────────────────────────────────────────────────────
# Connection string en formato JDBC. En el panel de Neon, copia el host/db y
# antepón "jdbc:". Neon EXIGE SSL, por eso va ?sslmode=require.
# Ejemplo:
#   jdbc:postgresql://ep-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=jdbc:postgresql://<HOST>.neon.tech/<DB>?sslmode=require
DATABASE_USER=<TU_USUARIO_NEON>
DATABASE_PASSWORD=<TU_PASSWORD_NEON>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Usa una cadena larga y aleatoria. Generar una:
#   openssl rand -base64 48
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ISSUER=focuslens-api
JWT_AUDIENCE=focuslens-app
JWT_REALM=focuslens
JWT_EXPIRES_IN_MS=86400000

# ── Servidor ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
